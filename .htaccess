Options -Indexes
ServerSignature Off

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Protect sensitive files
<FilesMatch "(config\.php|\.sql|\.log|\.env|composer\.(json|lock))$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to includes folder
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct includes access
    RewriteRule ^includes/ - [F,L]

    # Remove trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [R=301,L]

    # Pretty URLs for public pages (optional)
    # RewriteRule ^board/([^/]+)/?$ /public/board.php?slug=$1 [QSA,L]
    # RewriteRule ^roadmap/([^/]+)/?$ /public/roadmap.php?slug=$1 [QSA,L]
    # RewriteRule ^changelog/([^/]+)/?$ /public/changelog.php?slug=$1 [QSA,L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Disable access to uploads for PHP execution
<FilesMatch "\.(php|php3|php4|php5|phtml)$">
    <IfModule mod_rewrite.c>
        RewriteCond %{REQUEST_URI} ^/uploads/
        RewriteRule ^ - [F]
    </IfModule>
</FilesMatch>

# Upload directory protection
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.(php|php3|php4|php5|phtml)$ - [F,L]
</IfModule>
